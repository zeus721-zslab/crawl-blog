# === 필수 ===
# bcrypt 해시: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
PASSWORD_HASH=$2b...

# === LLM Provider ===
# 선택: claude (기본) | gemini | groq | ollama | mock (API 없이 크롤링 흐름 테스트용)
LLM_PROVIDER=claude

# Claude (LLM_PROVIDER=claude 시 필수)
ANTHROPIC_API_KEY=sk-...

# Gemini (LLM_PROVIDER=gemini 시 필수)
# pip install google-generativeai
GEMINI_API_KEY=AIza...

# Groq (LLM_PROVIDER=groq 시 필수)
# pip install groq
GROQ_API_KEY=gsk_...

# Ollama (LLM_PROVIDER=ollama 시 선택, 기본값 사용 가능)
OLLAMA_BASE_URL=http://localhost:11434

# === 선택 ===
CLAUDE_DAILY_LIMIT=100

# 프론트에서 API 호출할 공개 URL (게이트웨이 경유)
NEXT_PUBLIC_API_URL=https://crawl-blog.duckdns.org

# CORS — 프론트 도메인
ALLOWED_ORIGINS=https://crawl-blog.duckdns.org

# 쉼표 구분 도메인 블랙리스트 (크롤링 금지)
DOMAIN_BLACKLIST=example-blocked.com,another.com

# === MariaDB ===
DB_HOST=zslab_mariadb
DB_PORT=3306
DB_USER=crawl_blog
DB_PASSWORD=crawl_blog_2026!
DB_NAME=crawl_blog

# docker-compose image pull용 (서버 .env에 설정)
GITHUB_REPOSITORY=zeus721-zslab/crawl-blog
IMAGE_TAG=latest

# === Database ===
DB_HOST=your_db_host
DB_PORT=your_db_port
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name