# === 필수 ===
# bcrypt 해시: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
PASSWORD_HASH=$2b$12$...

# === LLM Provider ===
# 선택: claude (기본) | gemini | groq | ollama
LLM_PROVIDER=claude

# Claude (LLM_PROVIDER=claude 시 필수)
ANTHROPIC_API_KEY=sk-ant-...

# Gemini (LLM_PROVIDER=gemini 시 필수)
# pip install google-generativeai
GEMINI_API_KEY=AIza...

# Groq (LLM_PROVIDER=groq 시 필수)
# pip install groq
GROQ_API_KEY=gsk_...

# Ollama (LLM_PROVIDER=ollama 시 선택, 기본값 사용 가능)
OLLAMA_BASE_URL=http://localhost:11434

# === 선택 ===
CLAUDE_DAILY_LIMIT=100

# 프론트에서 API 호출할 공개 URL (게이트웨이 경유)
NEXT_PUBLIC_API_URL=https://crawl-blog.example.com

# CORS — 프론트 도메인
ALLOWED_ORIGINS=https://crawl-blog.example.com

# 쉼표 구분 도메인 블랙리스트 (크롤링 금지)
DOMAIN_BLACKLIST=example-blocked.com,another.com

# docker-compose image pull용 (서버 .env에 설정)
GITHUB_REPOSITORY=your-github-user/crawl-blog
IMAGE_TAG=latest
